{
  "name": "docai",
  "version": "1.0.0",
  "description": "Document AI service for extracting identity bio data with AWS Textract",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "start:dev": "tsx src/local.ts",
    "start": "npm run build && node dist/index.js",
    "build": "tsc",
    "deploy": "npm run build && serverless deploy",
    "deploy:dev": "npm run build && serverless deploy --stage dev",
    "deploy:staging": "npm run build && serverless deploy --stage staging",
    "test": "node --experimental-vm-modules --no-warnings=ExperimentalWarning node_modules/jest/bin/jest.js",
    "test:e2e": "NODE_ENV=localstack NODE_OPTIONS='--experimental-vm-modules --no-warnings=ExperimentalWarning' jest --config jest.e2e.config.js"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.2.0",
    "@aws-sdk/client-textract": "^3.988.0",
    "@codegenie/serverless-express": "^4.14.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "openapi3-ts": "^4.5.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "serverless": "^4.9.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}